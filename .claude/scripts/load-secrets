#!/bin/bash
# Push ~/.config/secrets.env into the launchd session environment so every
# launchd-launched job inherits the keys, with no per-plist edits. Run at login
# by com.johngavin.load-secrets, and can be re-run any time after editing the
# source file. (llm#791)
f="$HOME/.config/secrets.env"
[ -r "$f" ] || exit 0
set -a
. "$f"
set +a
for k in $(grep -oE '^(export +)?[A-Z0-9_]+=' "$f" | sed -E 's/^(export +)?//; s/=$//' | sort -u); do
  launchctl setenv "$k" "${!k}"
done
