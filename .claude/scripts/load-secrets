#!/bin/bash
# DEPRECATED (llm#791 / #615): this script used to push
# ~/.config/secrets.env into the launchd GUI-domain environment via
# `launchctl setenv`, so every launchd job (and every GUI-launched process
# on the machine) inherited the keys. That global exposure is readable by
# any process via `launchctl print gui/$UID/<any-job>` — a leak (#615).
#
# Secrets are now injected per-process by wrapping each job that needs one
# in `.claude/scripts/with-secrets` (see .claude/launchd/SECRETS_MIGRATION.md),
# which sources ~/.config/secrets.env into a single exec'd process instead
# of the shared launchd environment. com.johngavin.load-secrets is retired
# (see .claude/launchd/com.johngavin.load-secrets.plist.deprecated-2026-07-23).
#
# This script is kept only as a historical reference and intentionally does
# nothing destructive if invoked by hand.
exit 0
