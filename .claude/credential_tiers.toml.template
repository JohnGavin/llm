# credential_tiers.toml — Two-vault credential tier configuration
#
# SETUP: Copy this template to .claude/credential_tiers.toml (gitignored)
#   and populate with the actual key names from your ~/.Renviron.
#
#   cp .claude/credential_tiers.toml.template .claude/credential_tiers.toml
#
# FORMAT: Each section lists environment variable NAME strings (not values).
#   The permission_request.sh hook reads this file at runtime.
#
# RATIONALE:
#   [auto]  — Read-only keys, internal paths, and low-blast-radius credentials.
#             An agent may use these without a per-call human prompt.
#             Criteria: if compromised, attacker gains read access but cannot
#             mutate external state, spend money, or send communications.
#
#   [ask]   — High-value or write-capable keys. These require explicit human
#             confirmation before every use by an autonomous agent.
#             Criteria: if compromised, attacker can mutate data, incur costs,
#             send external communications, or delete production resources.
#
#   DEFAULT (unlisted key) — treated as [ask]. Zero-trust default: any key not
#             categorised is treated as high-risk until explicitly demoted.
#
# UPDATING: After rotating a key, no change needed here (names stay constant).
#   After adding a new key to .Renviron, add it to the appropriate tier here.
#   When in doubt, leave it in [ask] until you verify it is truly read-only.
#
# SECURITY: This file (the live copy) is gitignored. The template ships with
#   representative examples; your live file should list real key names from
#   your .Renviron. Never put credential VALUES in this file — key names only.
# ─────────────────────────────────────────────────────────────────────────────

[auto]
# Read-only keys and internal paths — no human prompt required per use.
# Examples (replace with your actual key names):
keys = [
  # GitHub fine-grained read-only token (contents:read, issues:read)
  "GITHUB_TOKEN_READ",
  # Internal DB path (filesystem path, not a secret — just a path)
  "ROBOREV_DB_PATH",
  # FRED (Federal Reserve Economic Data) — public read-only API
  "FRED_API_KEY",
  # R-universe read token if applicable
  "RUNIVERSE_TOKEN_READ",
  # Any key whose name contains _READ_ is a strong signal it belongs here
  # Add other confirmed read-only keys below:
]

[ask]
# Write-capable, billing, or high-value keys — explicit confirmation required.
# Examples (replace with your actual key names):
keys = [
  # Anthropic API — incurs cost per call, can be used for prompt injection
  "ANTHROPIC_API_KEY",
  # OpenAI — incurs cost per call
  "OPENAI_API_KEY",
  # Google AI — incurs cost per call
  "GOOGLE_API_KEY",
  # GitHub classic/write token — can push, delete, create releases
  "GITHUB_TOKEN",
  "GITHUB_TOKEN_WRITE",
  "GITHUB_PAT",
  # Cachix auth — can publish binary cache artifacts
  "CACHIX_AUTH_TOKEN",
  # ntfy.sh topic — can send push notifications to external service
  "NTFY_TOPIC",
  # Any payment or billing API key
  "STRIPE_SECRET_KEY",
  "STRIPE_API_KEY",
  # Production database credentials
  "DB_PASSWORD",
  "DB_USER",
  # Add other write/billing keys below:
]
